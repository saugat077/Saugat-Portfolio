---
import Nav from '../components/Nav.astro'
import Hero from '../components/Hero.astro'
import About from '../components/About.astro'
import BookReview from '../components/BookReview.astro'
import Experience from '../components/Experience.astro'
import Affiliations from '../components/Affiliations.astro'
import Projects from '../components/Projects.astro'
import '../styles/global.css'
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Saugat K.C. | Portfolio</title>
    <meta name="description" content="QA Engineer by profession, Designer by instinct. Portfolio of Saugat K.C. based in Kathmandu, Nepal." />
    <meta property="og:title" content="Saugat K.C. | Portfolio" />
    <meta property="og:description" content="QA Engineer by profession, Designer by instinct. Based in Kathmandu, Nepal." />
    <meta property="og:image" content="https://saugatkc77.com.np/images/og-preview.png" />
    <meta property="og:url" content="https://saugatkc77.com.np" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Saugat K.C. | Portfolio" />
    <meta name="twitter:image" content="https://saugatkc77.com.np/images/og-preview.png" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
  </head>

  <body class="bg-[#0a0a0a] min-h-screen text-white antialiased overflow-x-hidden">
    <Nav />

    <main class="max-w-[1440px] mx-auto">
      <div class="max-w-[760px] mx-auto px-6 xl:px-0 pt-[68px] sm:pt-[96px] pb-12 flex flex-col gap-16 sm:gap-28">
        <!-- Hero and About are tightly grouped — use inner gap instead of the outer gap-20 -->
        <div class="flex flex-col gap-4 sm:gap-5">
          <Hero />
          <About />
        </div>
        <BookReview />
        <Experience />
        <Affiliations />
        <Projects />
      </div>

      <!-- Decorative name watermark — centered, full word visible -->
      <div
        class="font-display text-[64px] sm:text-[160px] leading-none text-center text-white pointer-events-none select-none py-6 sm:py-8"
        style="-webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.49) 25%, rgba(0,0,0,0) 80%); mask-image: linear-gradient(to bottom, rgba(0,0,0,0.49) 25%, rgba(0,0,0,0) 80%);"
        aria-hidden="true"
      >
        SAUGATKC
      </div>
    </main>
  </body>
</html>
