---
import Nav from '../components/Nav.astro'
import Hero from '../components/Hero.astro'
import About from '../components/About.astro'
import BookReview from '../components/BookReview.astro'
import Experience from '../components/Experience.astro'
import Affiliations from '../components/Affiliations.astro'
import Projects from '../components/Projects.astro'
import '../styles/global.css'
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Saugat K.C.</title>
    <meta name="description" content="Portfolio of Saugat K.C., AI Powered QA Engineer based in Kathmandu, Nepal." />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
  </head>

  <body class="bg-[#0a0a0a] min-h-screen text-white antialiased overflow-x-hidden">
    <Nav />

    <main class="max-w-[1440px] mx-auto">
      <div class="max-w-[760px] mx-auto px-6 xl:px-0 pt-[68px] sm:pt-[96px] pb-12 flex flex-col gap-10 sm:gap-20">
        <!-- Hero and About are tightly grouped — use inner gap instead of the outer gap-20 -->
        <div class="flex flex-col gap-4 sm:gap-5">
          <Hero />
          <About />
        </div>
        <BookReview />
        <Experience />
        <Affiliations />
        <Projects />
      </div>

      <!-- Decorative name watermark — centered, full word visible -->
      <div
        class="font-display text-[64px] sm:text-[160px] leading-none text-center text-transparent bg-[linear-gradient(to_bottom,rgba(255,255,255,0.49)_25%,transparent_80%)] bg-clip-text pointer-events-none select-none py-6 sm:py-8"
        aria-hidden="true"
      >
        SAUGAT
      </div>
    </main>
  </body>
</html>
