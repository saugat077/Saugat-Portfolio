---
import Nav from '../../components/Nav.astro'
import { client, urlFor } from '../../lib/sanity'
import '../../styles/global.css'

export async function getStaticPaths() {
  const projects = await client.fetch(
    `*[_type == "project" && status == "published"]{ "slug": slug.current }`
  )
  return projects.map((project: { slug: string }) => ({
    params: { slug: project.slug },
  }))
}

// ── Types ──────────────────────────────────────────────────────────────────

interface PTSpan {
  _type: 'span'
  _key: string
  text: string
  marks: string[]
}

interface PTImageBlock {
  _type: 'image'
  _key: string
  asset: { _ref: string; _type: 'reference' }
}

interface PTTextBlock {
  _type: 'block'
  _key: string
  style: string
  children: PTSpan[]
  listItem?: 'bullet' | 'number'
  level?: number
}

type BodyBlock = PTTextBlock | PTImageBlock

interface Project {
  title: string
  shortDescription: string
  tags: string[]
  screenshot: {
    _type: 'image'
    asset: { _ref: string; _type: 'reference' }
  }
  liveUrl: string | null
  githubUrl: string | null
  body: BodyBlock[]
}

// ── Fetch ──────────────────────────────────────────────────────────────────

const { slug } = Astro.params

const project = await client.fetch<Project | null>(
  `*[_type == "project" && slug.current == $slug][0] {
    title,
    shortDescription,
    tags,
    screenshot,
    liveUrl,
    githubUrl,
    body
  }`,
  { slug }
)

if (!project) {
  return Astro.redirect('/404')
}

// ── Portable Text → HTML ───────────────────────────────────────────────────

function escapeHtml(str: string): string {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
}

function ptToHtml(blocks: BodyBlock[]): string {
  const parts: string[] = []
  let currentList: 'bullet' | 'number' | null = null

  for (const block of blocks) {
    // ── Image block ──
    if (block._type === 'image') {
      if (currentList) {
        parts.push(currentList === 'bullet' ? '</ul>' : '</ol>')
        currentList = null
      }
      const imgBlock = block as PTImageBlock
      const src = urlFor(imgBlock).width(760).url()
      parts.push(
        `<img src="${src}" alt="" class="w-full rounded-lg my-6" loading="lazy" decoding="async" />`
      )
      continue
    }

    // ── Text block ──
    const b = block as PTTextBlock
    if (!b.children?.length) continue

    const inlineHtml = b.children
      .map((span) => {
        let t = escapeHtml(span.text)
        if (span.marks.includes('strong')) t = `<strong class="font-semibold text-white">${t}</strong>`
        if (span.marks.includes('em')) t = `<em class="italic">${t}</em>`
        if (span.marks.includes('code')) t = `<code class="bg-[#18181b] text-[#a1a1aa] px-1 rounded text-sm">${t}</code>`
        return t
      })
      .join('')

    // ── List items ──
    if (b.listItem) {
      const listType = b.listItem
      if (currentList !== listType) {
        if (currentList) parts.push(currentList === 'bullet' ? '</ul>' : '</ol>')
        parts.push(
          listType === 'bullet'
            ? '<ul class="list-disc list-inside font-body text-[16px] text-[#a1a1aa] leading-relaxed space-y-2 my-4 ml-4">'
            : '<ol class="list-decimal list-inside font-body text-[16px] text-[#a1a1aa] leading-relaxed space-y-2 my-4 ml-4">'
        )
        currentList = listType
      }
      if (inlineHtml.trim()) parts.push(`<li>${inlineHtml}</li>`)
      continue
    }

    // Close any open list
    if (currentList) {
      parts.push(currentList === 'bullet' ? '</ul>' : '</ol>')
      currentList = null
    }

    if (!inlineHtml.trim()) continue

    // ── Block styles ──
    switch (b.style) {
      case 'h1':
        parts.push(`<h1 class="font-display text-3xl text-white mt-10 mb-4 leading-tight">${inlineHtml}</h1>`)
        break
      case 'h2':
        parts.push(`<h2 class="font-display text-2xl text-white mt-8 mb-3 leading-tight">${inlineHtml}</h2>`)
        break
      case 'h3':
        parts.push(`<h3 class="font-display text-xl text-white mt-6 mb-2 leading-tight">${inlineHtml}</h3>`)
        break
      case 'blockquote':
        parts.push(
          `<blockquote class="border-l-2 border-[#3f3f46] pl-4 my-4 font-body text-[16px] text-[#a1a1aa] italic leading-relaxed">${inlineHtml}</blockquote>`
        )
        break
      default:
        parts.push(
          `<p class="font-body text-[16px] text-[#d4d4d8] leading-relaxed mb-4">${inlineHtml}</p>`
        )
    }
  }

  if (currentList) parts.push(currentList === 'bullet' ? '</ul>' : '</ol>')
  return parts.join('\n')
}

const bodyHtml = project.body ? ptToHtml(project.body) : ''
const screenshotUrl = project.screenshot?.asset
  ? urlFor(project.screenshot).width(760).url()
  : null
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{project.title} | Saugat K.C.</title>
    <meta name="description" content={project.shortDescription} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
  </head>

  <body class="bg-[#0a0a0a] min-h-screen text-white antialiased">
    <Nav />

    <main class="max-w-[760px] mx-auto px-6 xl:px-0 pt-[88px] sm:pt-[112px] pb-24">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 mb-6 font-body text-[13px]" aria-label="Breadcrumb">
        <a href="/" class="text-[#52525b] hover:text-[#a1a1aa] transition-colors">Home</a>
        <span class="text-[#3f3f46]">/</span>
        <a href="/projects" class="text-[#52525b] hover:text-[#a1a1aa] transition-colors">Projects</a>
        <span class="text-[#3f3f46]">/</span>
        <span class="text-[#a1a1aa] truncate">{project.title}</span>
      </nav>

      <!-- Two-column hero -->
      <div class="flex flex-col md:flex-row gap-8 mb-8">
        <!-- Left: screenshot (60%) -->
        {screenshotUrl && (
          <div class="md:w-[60%] shrink-0 rounded-[16px] overflow-hidden bg-[#18181b] self-start">
            <img
              src={screenshotUrl}
              alt={`${project.title} screenshot`}
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
            />
          </div>
        )}

        <!-- Right: metadata (40%) -->
        <div class="flex flex-col gap-4 md:w-[40%]">
          <!-- Title -->
          <h1 class="font-display text-[28px] sm:text-[34px] text-white leading-tight">
            {project.title}
          </h1>

          <!-- Short description -->
          <p class="font-body text-[14px] text-[#a1a1aa] leading-relaxed">
            {project.shortDescription}
          </p>

          <!-- GitHub + Live buttons -->
          {(project.githubUrl || project.liveUrl) && (
            <div class="flex items-center gap-2">
              {project.githubUrl && (
                <a
                  href={project.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 font-body text-[12px] text-[#71717a] border border-[#3f3f46] rounded-full px-3 py-1 hover:border-[#52525b] hover:text-[#a1a1aa] transition-colors"
                >
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
                  </svg>
                  GitHub
                </a>
              )}
              {project.liveUrl && (
                <a
                  href={project.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 font-body text-[12px] text-[#71717a] border border-[#3f3f46] rounded-full px-3 py-1 hover:border-[#52525b] hover:text-[#a1a1aa] transition-colors"
                >
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                  Live
                </a>
              )}
            </div>
          )}

          <!-- Tags -->
          {project.tags?.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
              {project.tags.map((tag) => (
                <span class="bg-[#18181b] border border-[#27272a] rounded px-2 py-0.5 font-body text-[11px] text-[#71717a] whitespace-nowrap leading-[16px]">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>

      <!-- Divider -->
      <hr class="border-[#27272a] mb-8" />

      <!-- Body -->
      {bodyHtml ? (
        <div set:html={bodyHtml} />
      ) : (
        <p class="font-body text-[16px] text-[#71717a] italic">Write-up coming soon.</p>
      )}

      <!-- Back link -->
      <div class="mt-12">
        <a
          href="/projects"
          class="inline-flex items-center gap-1.5 font-body text-[13px] text-[#71717a] hover:text-white transition-colors"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10 12L6 8l4-4"/>
          </svg>
          Back to projects
        </a>
      </div>
    </main>
  </body>
</html>
