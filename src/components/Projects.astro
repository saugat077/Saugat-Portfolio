---
import { client, urlFor } from '../lib/sanity'

interface Project {
  _id: string
  title: string
  shortDescription: string
  screenshot: {
    _type: 'image'
    asset: { _ref: string; _type: 'reference' }
  }
  githubUrl: string
  tags: string[]
  slug: { current: string }
}

const projects = await client.fetch<Project[]>(
  `*[_type == "project" && status == "published"] | order(_createdAt desc) [0...2] {
    _id,
    title,
    shortDescription,
    screenshot,
    githubUrl,
    tags,
    slug
  }`
)
---

{projects.length > 0 && (
  <section class="flex flex-col gap-6">
    <!-- Section header -->
    <div class="flex items-center justify-between">
      <h2 class="font-display text-[18px] sm:text-[23px] text-white">Projects</h2>
      <a
        href="/projects"
        class="font-display text-[10px] text-white hover:text-[#a1a1aa] transition-colors"
      >
        View more &gt;
      </a>
    </div>

    <!-- Project cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 sm:gap-[74px]">
      {projects.map((project) => (
        <div class="flex flex-col gap-[10px]">
          <!-- Screenshot -->
          <a
            href={project.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="block rounded-[16px] sm:rounded-[21px] overflow-hidden h-[190px] sm:h-[229px] bg-[#18181b] hover:opacity-90 transition-opacity focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40"
            aria-label={`View ${project.title} on GitHub`}
            tabindex="-1"
          >
            {project.screenshot?.asset ? (
              <img
                src={urlFor(project.screenshot).width(760).height(458).url()}
                alt={`${project.title} screenshot`}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-[#18181b] to-[#27272a]"></div>
            )}
          </a>

          <!-- Title + external link -->
          <div class="flex items-center justify-between gap-2">
            <h3 class="font-body font-bold text-[20px] sm:text-[27px] text-white leading-tight">
              {project.title}
            </h3>
            <a
              href={project.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`View ${project.title} source`}
              class="text-white hover:text-[#a1a1aa] transition-colors shrink-0"
            >
              <!-- Diagonal arrow (↗) -->
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M7 17 17 7M7 7h10v10"/>
              </svg>
            </a>
          </div>

          <!-- Short description -->
          <p class="font-body text-[15px] sm:text-[19px] text-white leading-snug">
            {project.shortDescription}
          </p>

          <!-- Tags -->
          {project.tags?.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="bg-[#18181b] border border-[#27272a] rounded px-2 py-1 sm:px-[9px] sm:py-[5px] font-body text-[11px] sm:text-[13px] text-[#a1a1aa] whitespace-nowrap leading-[16px] sm:leading-[18px]">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
)}
