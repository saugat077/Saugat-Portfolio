---
import { client } from '../lib/sanity'
import BookCard from './BookCard.astro'

interface Book {
  _id: string
  title: string
  author: string
  coverImage: {
    _type: 'image'
    asset: { _ref: string; _type: 'reference' }
  }
  slug: { current: string }
}

const books = await client.fetch<Book[]>(
  `*[_type == "book" && status == "published"] | order(_createdAt desc) [0...4] {
    _id,
    title,
    author,
    coverImage,
    slug
  }`
)
---

{books.length > 0 && (
  <section class="flex flex-col gap-6">
    <!-- Section header -->
    <div class="flex items-center justify-between">
      <h2 class="font-display text-[18px] sm:text-[23px] text-white">Book Review</h2>
      <a
        href="/books"
        class="font-body text-[13px] text-white hover:text-[#a1a1aa] transition-colors"
      >
        View more &gt;
      </a>
    </div>

    <!-- Book covers row — 4 fixed-size cards; scrollable on mobile -->
    <div class="flex gap-[10px] sm:gap-[14px] items-start overflow-x-auto pb-1 -mb-1">
      {books.map((book) => (
        <BookCard
          title={book.title}
          author={book.author}
          coverImage={book.coverImage}
          slug={book.slug.current}
        />
      ))}
    </div>
  </section>
)}
