---
import { urlFor } from '../lib/sanity'

interface Props {
  title: string
  author: string
  coverImage: {
    _type: 'image'
    asset: { _ref: string; _type: 'reference' }
  } | null | undefined
  slug: string
}

const { title, author, coverImage, slug } = Astro.props

const coverUrl = coverImage?.asset
  ? urlFor(coverImage).width(360).height(576).url()
  : null
---

<a
  href={`/books/${slug}`}
  class="group relative block w-[140px] h-[224px] sm:w-[179px] sm:h-[287px] shrink-0 overflow-hidden rounded-lg bg-[#18181b] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40"
  title={`${title}`}
>
  {coverUrl ? (
    <img
      src={coverUrl}
      alt={`${title} cover`}
      class="w-full h-full object-cover transition-transform duration-300 ease-out group-hover:scale-105"
      loading="lazy"
      decoding="async"
    />
  ) : (
    <div class="w-full h-full flex items-end p-3 border border-[#27272a] rounded-lg">
      <span class="font-body text-[13px] text-[#a1a1aa] line-clamp-3 leading-tight">{title}</span>
    </div>
  )}

  <!-- Hover overlay: fades in, anchored to bottom -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 ease-out flex flex-col justify-end p-3">
    <p class="font-display text-[13px] text-white leading-snug line-clamp-2">{title}</p>
    <p class="font-body text-[11px] text-[#a1a1aa] mt-0.5 line-clamp-1">{author}</p>
  </div>
</a>
